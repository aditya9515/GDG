{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ExtractedDocumentBatch",
  "type": "object",
  "required": ["incidents", "teams", "resources", "document_summary", "warnings"],
  "properties": {
    "incidents": {
      "type": "array",
      "items": {
        "$ref": "incident-extraction.schema.json"
      }
    },
    "teams": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["display_name", "capability_tags", "base_label", "current_label", "member_ids", "reliability_score", "notes"],
        "properties": {
          "team_id": { "type": ["string", "null"] },
          "display_name": { "type": ["string", "null"] },
          "capability_tags": { "type": "array", "items": { "type": "string" } },
          "base_label": { "type": ["string", "null"] },
          "base_geo": {
            "type": ["object", "null"],
            "required": ["lat", "lng"],
            "properties": {
              "lat": { "type": "number" },
              "lng": { "type": "number" }
            }
          },
          "current_label": { "type": ["string", "null"] },
          "current_geo": {
            "type": ["object", "null"],
            "required": ["lat", "lng"],
            "properties": {
              "lat": { "type": "number" },
              "lng": { "type": "number" }
            }
          },
          "member_ids": { "type": "array", "items": { "type": "string" } },
          "service_radius_km": { "type": ["number", "null"], "minimum": 0 },
          "availability_status": { "type": ["string", "null"], "enum": ["AVAILABLE", "ON_MISSION", "OFFLINE", null] },
          "active_dispatches": { "type": ["integer", "null"], "minimum": 0 },
          "reliability_score": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
          "evidence_ids": { "type": "array", "items": { "type": "string" } },
          "notes": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "resources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["resource_type", "quantity_available", "location_label", "current_label", "constraints", "owning_team_id"],
        "properties": {
          "resource_id": { "type": ["string", "null"] },
          "resource_type": { "type": "string" },
          "quantity_available": { "type": ["number", "null"], "minimum": 0 },
          "location_label": { "type": ["string", "null"] },
          "location": {
            "type": ["object", "null"],
            "required": ["lat", "lng"],
            "properties": {
              "lat": { "type": "number" },
              "lng": { "type": "number" }
            }
          },
          "current_label": { "type": ["string", "null"] },
          "current_geo": {
            "type": ["object", "null"],
            "required": ["lat", "lng"],
            "properties": {
              "lat": { "type": "number" },
              "lng": { "type": "number" }
            }
          },
          "constraints": { "type": "array", "items": { "type": "string" } },
          "owning_team_id": { "type": ["string", "null"] },
          "evidence_ids": { "type": "array", "items": { "type": "string" } },
          "image_url": { "type": ["string", "null"] }
        }
      }
    },
    "document_summary": {
      "type": ["string", "null"]
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
