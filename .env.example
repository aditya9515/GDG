# Backend (api/.env also supported)
APP_ENV=development
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","https://__SET_FIREBASE_APP_HOSTING_DOMAIN__"]
FIREBASE_PROJECT_ID=gdg-ngo-resource-aloocation
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
FIREBASE_TOKEN_CLOCK_SKEW_SECONDS=10
REPOSITORY_BACKEND=firestore
ALLOW_DEMO_AUTH=false
GOOGLE_MAPS_API_KEY=your-server-side-maps-key
GEMINI_API_KEY=your-gemini-key
AI_PROVIDER=gemini
GEMINI_ENABLED=true
GEMMA4_ENABLED=false

# Local-only Gemma4/Ollama settings. Keep GEMMA4_ENABLED=false in production.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma4:e2b
OLLAMA_TIMEOUT_SECONDS=90

# Frontend (web/.env.local also supported)
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
NEXT_PUBLIC_ENABLE_DEMO_AUTH=false
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-web-api-key
NEXT_PUBLIC_FIREBASE_APP_ID=your-firebase-app-id
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=gdg-ngo-resource-aloocation
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-browser-maps-key
